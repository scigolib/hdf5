  v00 = 0, 1, 2 ; v01 = 1, 2, 3 ; v02 = 2, 3, 4 ; v03 = 3, 4, 5 ;
  v04 = 4, 5, 6 ; v05 = 5, 6, 7 ; v06 = 6, 7, 8 ; v07 = 7, 8, 9 ;
